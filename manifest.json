{
    "manifest_version": 3,
    "name": "AI PR Reviewer",
    "version": "1.0",

    "action": {
        "default_title": "AI PR Reviewer"
    },

    "permissions": [
        "storage",
        "identity",
        "activeTab",
        "scripting"
    ],

    "host_permissions": [
        "https://github.com/*",
        "https://api.github.com/*",

        "https://gitlab.com/*",
        "https://gitlab.com/api/*"
    ],
    "optional_host_permissions": [
        "https://*/*"
    ],

    "background": {
        "service_worker": "background.js"
    }
}