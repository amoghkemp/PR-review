{
    "manifest_version": 3,
    "name": "AI PR Reviewer",
    "version": "1.0",

    "action": {
        "default_title": "AI PR Reviewer"
    },

    "permissions": [
        "activeTab",
        "storage",
        "scripting"
    ],

    "host_permissions": [
        "https://github.com/*",
        "https://api.github.com/*",

        "https://gitlab.com/*",
        "https://gitlab.com/api/*",

        "https://git.routematic.com/api/*"
    ],

    "background": {
        "service_worker": "background.js"
    },

    "content_scripts": [
        {
            "matches": [
                "https://github.com/*/pull/*",
                "https://gitlab.com/*/-/merge_requests/*",

                "https://git.routematic.com/*/-/merge_requests/*"
            ],
            "js": [
                "config.js",
                "github.js",
                "gitlab.js",
                "git.js",
                "promptBuilder.js",
                "providers/gemini.js",
                "llm.js",
                "content.js"
            ],
            "css": [
                "styles.css"
            ]
        }
    ]
}